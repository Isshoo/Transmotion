{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "strict": false,
    "checkJs": false,
    "maxNodeModuleJsDepth": 1,
    "typeRoots": ["./node_modules/@types"],
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.js", "**/*.jsx"],
  "exclude": ["node_modules", ".next", "out", "build"]
}
